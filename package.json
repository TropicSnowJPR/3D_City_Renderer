{
  "name": "3d-map-generator",
  "version": "5.0.0",
  "private": true,
  "description": "",
  "type": "module",
  "main": "Main.js",
  "scripts": {
    "server": "npm install && tsc && vite build --config src/vite.config.ts && node src/Server.ts",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest",
    "test:browser": "vitest --config=vitest.browser.config.ts",
    "docs": "jsdoc -c jsdoc.json",
    "build-zip": "npm install && tsc && vite build --config src/vite.config.ts && node scripts/build-zip.js"
  },
  "dependencies": {
    "@geoman-io/leaflet-geoman-free": "^2.19.2",
    "@mapbox/mapbox-gl-draw": "^1.5.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "archiver": "^7.0.1",
    "async": "^3.2.6",
    "cors": "^2.8.6",
    "cross-fetch": "^4.1.0",
    "earcut": "^3.0.2",
    "express": "^5.2.1",
    "fs-extra": "^11.3.4",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "martinez-polygon-clipping": "^0.8.1",
    "overpass-ql-ts": "^1.11.0",
    "proj4": "^2.20.3",
    "three": "^0.183.2",
    "three-bvh-csg": "^0.0.18",
    "three-mesh-bvh": "^0.9.9"
  },
  "devDependencies": {
    "@microsoft/tsdoc": "^0.16.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/leaflet": "^1.9.21",
    "@types/three": "^0.183.1",
    "@vitest/browser-playwright": "^4.1.1",
    "lil-gui": "^0.21.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.1"
  }
